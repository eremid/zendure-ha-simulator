# Git submodule / external clone
Zendure-HA/

# Python
__pycache__/
*.pyc
*.pyo

# Environment / secrets
.env
.env.*

# Simulation outputs
*.csv

# Plots generated by plot.py
*.png
*.pdf

# ──────────────────────────────────────────────
# Home Assistant — runtime data
# Keep: homeassistant/configuration.yaml
# ──────────────────────────────────────────────

# Version & lock files
homeassistant/.HA_VERSION
homeassistant/.ha_run.lock

# Storage — contains auth tokens, hashed passwords, registry state
homeassistant/.storage/

# SQLite database
homeassistant/home-assistant_v2.db
homeassistant/home-assistant_v2.db-shm
homeassistant/home-assistant_v2.db-wal

# Logs
homeassistant/home-assistant.log
homeassistant/home-assistant.log.*
